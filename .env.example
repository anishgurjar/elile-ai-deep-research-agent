# =============================================================================
# ELILEAI Monorepo Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# =============================================================================

APP_ENV=development
NODE_ENV=development

# -----------------------------------------------------------------------------
# Shared Infrastructure (from docker-compose.yml)
# -----------------------------------------------------------------------------

# Postgres Database
ELILEAI_SHARED_POSTGRES_HOST=localhost
ELILEAI_SHARED_POSTGRES_PORT=5432
ELILEAI_SHARED_POSTGRES_DB_NAME=elileai
ELILEAI_SHARED_POSTGRES_USER=elileai
ELILEAI_SHARED_POSTGRES_PASSWORD=elileai_dev
DATABASE_URL=postgresql://elileai:elileai_dev@localhost:5432/elileai

# Legacy DB vars (used by assistant-app)
DB_HOST=localhost
DB_PORT=5432
DB_USER=elileai
DB_PASSWORD=elileai_dev
DB_NAME=elileai

# Neo4j (Identity Graph)
ELILEAI_NEO4J_URI=bolt://localhost:7687
ELILEAI_NEO4J_USERNAME=neo4j
ELILEAI_NEO4J_PASSWORD=neo4j_dev
ELILEAI_NEO4J_DATABASE=neo4j
ELILEAI_IDGRAPH_INGESTION_MODE=langchain_graph_documents

# Neo4j (Identity Graph) - Read-only tool user (created by neo4j-init service)
ELILEAI_NEO4J_READ_URI=bolt://localhost:7687
ELILEAI_NEO4J_READ_USERNAME=neo4j_read
ELILEAI_NEO4J_READ_PASSWORD=neo4j_read_dev
ELILEAI_NEO4J_READ_DATABASE=neo4j

# -----------------------------------------------------------------------------
# Port Overrides (for parallel dev stacks)
# -----------------------------------------------------------------------------
# Override host-side ports to avoid conflicts when running multiple stacks.
# Defaults match the original hardcoded values.
#
# COMPOSE_PROJECT_NAME=elileai
# ELILEAI_POSTGRES_PORT=5432
# ELILEAI_LANGGRAPH_PORT=2024

# -----------------------------------------------------------------------------
# AI Services
# -----------------------------------------------------------------------------

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5.2

# Research subagent (uses OpenAI native web search tool)
# Recommended: gpt-4.1 (fast, reliable web search support)
ELILEAI_RESEARCH_MODEL=gpt-4.1

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# LangSmith (observability)
LANGSMITH_API_KEY=your-langsmith-api-key-here

# -----------------------------------------------------------------------------
# Clerk Authentication
# -----------------------------------------------------------------------------

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_ZmFpdGhmdWwtbW9jY2FzaW4tNTkuY2xlcmsuYWNjb3VudHMuZGV2JA
CLERK_SECRET_KEY=your-clerk-secret-key-here
CLERK_FRONTEND_API=your-clerk-frontend-api-here

# -----------------------------------------------------------------------------
# LangGraph (assistant-app)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_LANGGRAPH_API_URL=http://localhost:2024
NEXT_PUBLIC_LANGGRAPH_ASSISTANT_ID=elileai-conventional
NEXT_PUBLIC_CONVENTIONAL_AGENT_ID=elileai-conventional
NEXT_PUBLIC_FHA_AGENT_ID=elileai-fha

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------

NEXT_PUBLIC_APP_URL=http://localhost:3000
