APP_ENV=test

# Database
DATABASE_URL=postgresql://elileai:elileai_dev@localhost:5432/elileai_test
ELILEAI_SHARED_POSTGRES_DB_NAME=elileai_test

# OpenAI - dummy key to mimic CI, use real key for VCR re-record
OPENAI_API_KEY="sk-proj-placeholder-use-real-key-for-vcr-rerecord"

# Anthropic - dummy key to mimic CI, use real key for VCR re-record
ANTHROPIC_API_KEY="sk-ant-placeholder-use-real-key-for-vcr-rerecord"

# LangGraph
NEXT_PUBLIC_LANGGRAPH_API_URL=http://localhost:2024
NEXT_PUBLIC_LANGGRAPH_ASSISTANT_ID=elileai-orchestrator

# Clerk - uncomment both to re-record Polly cassettes with a real session JWT
CLERK_TEST_USER_ID=your-clerk-test-user-id-here
CLERK_SECRET_KEY=your-clerk-secret-key-here
